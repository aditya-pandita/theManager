{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Decidr Code",
  "version": "1.0.0",
  "identifier": "com.decidr.code",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --workspace=packages/web",
    "frontendDist": "../packages/web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Decidr Code",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": []
  }
}
